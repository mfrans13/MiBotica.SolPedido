<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiBotica</title>
    
    <!-- Bootstrap 5 CSS (CDN - no necesita descargar) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome para íconos -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #343a40;
        }
        .sidebar a {
            color: white;
            text-decoration: none;
            display: block;
            padding: 10px 15px;
        }
        .sidebar a:hover {
            background-color: #007bff;
        }
        .content-wrapper {
            padding: 20px;
        }
        .navbar-brand {
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar (menú lateral) -->
            <div class="col-md-2 sidebar p-0">
                <div class="text-center py-3 bg-dark">
                    <h5 class="text-white">MiBotica</h5>
                </div>
                <nav class="nav flex-column">
                    @await Component.InvokeAsync("Menu")
                </nav>
            </div>
            
            <!-- Contenido principal -->
            <div class="col-md-10 p-0">
                <!-- Navbar superior -->
                <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
                    <div class="container-fluid">
                        <span class="navbar-brand">Sistema de Gestión</span>
                            <div class="dropdown ms-auto">
                            @if (User?.Identity?.IsAuthenticated == true)
                                {
                                <button class="btn btn-light dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user"></i> 
                                    @User.Claims.FirstOrDefault(c => c.Type == "Nombres")?.Value
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="@Url.Action("Logout", "Login")">Cerrar Sesión</a></li>
                                </ul>
                                    }
                                    else
                                    {
                                <a class="btn btn-light" href="@Url.Action("Index", "Login")">Iniciar Sesión</a>
                                }
                        </div>
                    </div>
                </nav>
                
                <!-- Contenido -->
                <div class="content-wrapper">
                    @RenderBody()
                </div>
                
                <!-- Footer -->
                <footer class="text-center py-3 bg-light mt-3">
                    <span>&copy; 2025 MiBotica - Todos los derechos reservados</span>
                </footer>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>